<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DiamondInventory.Views.DiamondFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource PageBackgroundBrush}">

    <Grid Padding="32">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="1">
            <StackPanel Spacing="16" MaxWidth="500">
                <TextBlock Text="{x:Bind ViewModel.Title}" FontSize="28" FontWeight="Light" Foreground="White" Margin="0,0,0,16"/>

                <Border x:Name="ImagePreviewBorder" Width="200" Height="200" BorderBrush="{StaticResource GoldBrush}" 
                        BorderThickness="2" CornerRadius="12" HorizontalAlignment="Left" Tapped="OnImageTapped"
                        PointerPressed="OnImagePressed">
                    <Grid>
                        <Image x:Name="PreviewImage" Stretch="UniformToFill"/>
                        <TextBlock x:Name="PlaceholderText" Text="Cliquez pour ajouter une image" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                                   Foreground="{StaticResource GoldBrush}" TextWrapping="Wrap" TextAlignment="Center" Padding="16"/>
                    </Grid>
                </Border>

                <TextBlock Text="Nom *" Foreground="{StaticResource GoldBrush}" FontSize="12" Opacity="0.8"/>
                <TextBox Text="{x:Bind ViewModel.Nom, Mode=TwoWay}" PlaceholderText="Nom du diamant" Style="{StaticResource LuxuryTextBoxStyle}"/>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Carats" Foreground="{StaticResource GoldBrush}" FontSize="12" Opacity="0.8"/>
                        <TextBox Text="{x:Bind ViewModel.Carats, Mode=TwoWay}" PlaceholderText="0.00"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Prix (€)" Foreground="{StaticResource GoldBrush}" FontSize="12" Opacity="0.8"/>
                        <TextBox Text="{x:Bind ViewModel.Prix, Mode=TwoWay}" PlaceholderText="0"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Stock" Foreground="{StaticResource GoldBrush}" FontSize="12" Opacity="0.8"/>
                <TextBox Text="{x:Bind ViewModel.Stock, Mode=TwoWay}" PlaceholderText="1"/>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Couleur" Foreground="{StaticResource GoldBrush}" FontSize="12" Opacity="0.8"/>
                        <TextBox Text="{x:Bind ViewModel.Couleur, Mode=TwoWay}" PlaceholderText="D, E, F..."/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Clarté" Foreground="{StaticResource GoldBrush}" FontSize="12" Opacity="0.8"/>
                        <TextBox Text="{x:Bind ViewModel.Clarte, Mode=TwoWay}" PlaceholderText="IF, VVS1..."/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Notes" Foreground="{StaticResource GoldBrush}" FontSize="12" Opacity="0.8"/>
                <TextBox Text="{x:Bind ViewModel.Notes, Mode=TwoWay}" AcceptsReturn="True" 
                         TextWrapping="Wrap" Height="100" PlaceholderText="Notes supplémentaires..."/>

                <TextBlock Text="{x:Bind ViewModel.ErrorMessage}" Foreground="{StaticResource ErrorBrush}" 
                           FontSize="12" Visibility="{x:Bind ViewModel.ErrorMessage, Converter={StaticResource StringNotEmptyToVisibility}}"/>

                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
                    <Button Content="Annuler" Click="OnCancel" Style="{StaticResource OutlineGoldButtonStyle}"/>
                    <Button Content="Enregistrer" Click="OnSave" Style="{StaticResource GoldButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
