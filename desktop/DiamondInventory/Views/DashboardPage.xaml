<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DiamondInventory.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:DiamondInventory.ViewModels"
    xmlns:models="using:DiamondInventory.Models"
    mc:Ignorable="d"
    Background="{StaticResource PageBackgroundBrush}">

    <Page.Resources>
        <DataTemplate x:Key="DiamondCardTemplate" x:DataType="models:Diamond">
            <Border Style="{StaticResource LuxuryCardStyle}" Width="280" Margin="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="180"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="12" Clip="{x:Null}">
                        <Image Source="{x:Bind ImagePath, FallbackValue={x:Null}, TargetNullValue={x:Null}}" 
                               Stretch="UniformToFill" HorizontalAlignment="Center"/>
                    </Border>
                    <Grid Grid.Row="1" Padding="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{x:Bind Nom}" FontSize="18" FontWeight="SemiBold" 
                                   Foreground="White" TextTrimming="CharacterEllipsis"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" Margin="0,4">
                            <TextBlock Text="{x:Bind Carats}" FontSize="14" Opacity="0.7" Foreground="White"/>
                            <TextBlock Text="ct" FontSize="14" Opacity="0.7" Foreground="White"/>
                        </StackPanel>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0">
                                <Run Text="{x:Bind Prix}" FontWeight="Bold" Foreground="{StaticResource GoldBrush}" FontSize="16"/>
                                <Run Text=" €" Foreground="{StaticResource GoldBrush}" FontSize="16"/>
                            </TextBlock>
                            <Border Grid.Column="1" Background="{StaticResource GoldBrush}" CornerRadius="4" Padding="6,2" 
                                    Visibility="{x:Bind IsOutOfStock}">
                                <TextBlock Text="Rupture de stock" FontSize="11" FontWeight="Bold" Foreground="Black"/>
                            </Border>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                       Visibility="{x:Bind IsOutOfStock, Converter={StaticResource InverseBoolConverter}}">
                                <TextBlock Text="{x:Bind Stock}" Foreground="{StaticResource GoldBrush}" FontSize="12"/>
                                <TextBlock Text="en stock" Foreground="{StaticResource GoldBrush}" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Collection" FontSize="32" FontWeight="Light" 
                   Foreground="White" Margin="0,0,0,24"/>

        <ScrollViewer Grid.Row="1">
            <ItemsRepeater x:Name="DiamondsRepeater" Layout="{StaticResource UniformGridLayout}"
                          ItemsSource="{x:Bind ViewModel.Diamonds}"
                          ItemTemplate="{StaticResource DiamondCardTemplate}"/>
        </ScrollViewer>

        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
              Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}">
            <TextBlock Text="Aucun diamant" FontSize="20" Opacity="0.5" Foreground="White"/>
        </Grid>
    </Grid>
</Page>
