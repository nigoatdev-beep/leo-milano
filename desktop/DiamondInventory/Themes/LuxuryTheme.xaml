<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="GoldColor">#D4AF37</Color>
    <Color x:Key="GoldDarkColor">#AA8C2C</Color>
    <Color x:Key="GoldLightColor">#E5C76B</Color>
    <SolidColorBrush x:Key="GoldBrush" Color="{StaticResource GoldColor}"/>
    <SolidColorBrush x:Key="GoldDarkBrush" Color="{StaticResource GoldDarkColor}"/>
    <SolidColorBrush x:Key="GoldLightBrush" Color="{StaticResource GoldLightColor}"/>

    <Color x:Key="BackgroundDark">#0D0D0D</Color>
    <Color x:Key="SurfaceDark">#1A1A1A</Color>
    <Color x:Key="SurfaceElevated">#262626</Color>

    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource SurfaceDark}"/>
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="{StaticResource BackgroundDark}"/>
    <SolidColorBrush x:Key="ErrorBrush">#FF5252</SolidColorBrush>

    <Style x:Key="LuxuryCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#333333"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style x:Key="GoldButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource GoldBrush}"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20,10"/>
    </Style>

    <Style x:Key="OutlineGoldButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,8"/>
    </Style>

    <Style x:Key="LuxuryTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="#1A1A1A"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#333333"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>

    <converters:InverseBoolConverter x:Key="InverseBoolConverter" xmlns:converters="using:DiamondInventory.Converters"/>
    <converters:StringNotEmptyToVisibility x:Key="StringNotEmptyToVisibility" xmlns:converters="using:DiamondInventory.Converters"/>

    <UniformGridLayout x:Key="UniformGridLayout" MinItemWidth="280" MinItemHeight="280" ItemsStretch="Uniform"/>
</ResourceDictionary>
